rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Dokumenty kapitána: jen vlastní složka users/{uid}/
    match /users/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size > 0
        && request.resource.size < 15 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
    }

    // Dokumenty týmu: jen kapitán, jen když tým existuje ve Firestore a je pending
    match /teams/{teamId}/{fileName} {
      allow read: if request.auth != null
        && firestore.exists(/databases/(default)/documents/teams/$(teamId))
        && firestore.get(/databases/(default)/documents/teams/$(teamId)).data.captainId
          == request.auth.uid;

      allow write: if request.auth != null
        && request.resource.size > 0
        && request.resource.size < 15 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        )
        && firestore.exists(/databases/(default)/documents/teams/$(teamId))
        && firestore.get(/databases/(default)/documents/teams/$(teamId)).data.captainId
          == request.auth.uid
        && firestore.get(/databases/(default)/documents/teams/$(teamId)).data.status
          == 'pending';
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
