# Firebase (klient) — na Vercelu: Settings → Environment Variables → přidej všechny
# NEXT_PUBLIC_* řádky z konzole Firebase (Project settings → Your apps).
# Po změně NEXT_PUBLIC_* vždy znovu „Deploy“ (hodnoty se vkládají při buildu).

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server – JSON na jeden řádek nebo cesta k souboru)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Admin e-maily (čárkou oddělené) – API, /admin, /edit, CMS (kromě super admina v lib/super-admin.ts)
ADMIN_EMAILS=jiri@esportarena.cz

# Stejné e-maily jako ADMIN_EMAILS pro přesměrování po přihlášení na /admin (jen pro účty mimo super admin).
# Bez tohoto tě po přihlášení nepustí klient na /admin (i když ADMIN_EMAILS na serveru funguje pro API).
# NEXT_PUBLIC_ADMIN_EMAILS=admin@skola.cz,druhy@domena.cz

# Volitelně: project ID jen pro server (JWT ověření bez správného NEXT_PUBLIC při buildu na Netlify)
# FIREBASE_PROJECT_ID=tvoj-projekt-id

# Dočasný náhled /admin bez přihlášení — cookie na 7 dní (po odladění vypni / smaž env)
# Varianta A: jen otevřeš https://tvůj-web/admin-docasny-pristup (kdokoli na internetu — jen na krátkou dobu!)
ADMIN_DOCASNY_JEN_CESTA=1
# Varianta B (bezpečnější): smaž ADMIN_DOCASNY_JEN_CESTA a nastav token; URL pak /admin-docasny-pristup?t=TVŮJ_TOKEN
# ADMIN_DOCASNY_TOKEN=nahodny_dlouhy_retezec

# Discord webhook (admin upozornění)
DISCORD_WEBHOOK_URL=

# Tajný klíč pro POST /api/announcements/from-discord (Discord bot)
DISCORD_ANNOUNCEMENTS_SECRET=

# URL pro Discord bota (produkce), např. https://tvuj-web.netlify.app
ANNOUNCEMENTS_INGEST_URL=

# Resend (potvrzovací e-maily kapitánům: welcome, profil, odeslání týmu)
# Bez RESEND_API_KEY + RESEND_FROM API vrací 503 a e-mail nedorazí.
# RESEND_FROM musí být z ověřené domény v Resend (nebo onboarding@resend.dev jen pro test).
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
ADMIN_ALERT_EMAIL=jiri@esportarena.cz

# Faceit Data API
FACEIT_API_KEY=

# Volitelné: hero video loop (URL), oficiální Twitch kanál
NEXT_PUBLIC_HERO_VIDEO_URL=
NEXT_PUBLIC_TWITCH_CHANNEL=esportarenaplzen

# Cron mazání Storage (48h) + LFG inzerátů (60 dní) — Bearer u /api/cron/*
# Netlify: netlify/functions/cleanup-storage-cron.mjs volá storage + cleanup-lfg
# Vercel: vercel.json (dva crony)
CRON_SECRET=

# Jednorázové ukázkové inzeráty LFG (volitelné): npm run seed:lfg

# Po schválení – odkaz na Faceit kvalifikaci (zobrazí se týmu)
NEXT_PUBLIC_FACEIT_HUB_URL=https://www.faceit.com/
