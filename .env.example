# Firebase (klient)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server – JSON na jeden řádek nebo cesta k souboru)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Admin e-maily (čárkou oddělené) – přístup k /admin API
ADMIN_EMAILS=jiri@esportarena.cz

# Discord webhook (admin upozornění)
DISCORD_WEBHOOK_URL=

# Resend
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
ADMIN_ALERT_EMAIL=jiri@esportarena.cz

# Faceit Data API
FACEIT_API_KEY=

# Volitelné: hero video loop (URL), oficiální Twitch kanál
NEXT_PUBLIC_HERO_VIDEO_URL=
NEXT_PUBLIC_TWITCH_CHANNEL=esportarenaplzen

# Cron mazání souborů (volání z Vercel Cron / externí scheduler)
CRON_SECRET=

# Po schválení – odkaz na Faceit kvalifikaci (zobrazí se týmu)
NEXT_PUBLIC_FACEIT_HUB_URL=https://www.faceit.com/
