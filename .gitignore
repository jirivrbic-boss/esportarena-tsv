# env files (šablona .env.example se commituje)
.env
.env.local
.env.*.local
.env.development
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo

# lokální fotky v kořeni (veřejné assety jsou v public/fotky/)
/fotky/
